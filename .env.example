# Turso Database Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get these from:
#   turso db show <your-db-name>    → TURSO_URL
#   turso db tokens create <db>     → TURSO_TOKEN

TURSO_URL=libsql://your-db-name-xxx.turso.io
TURSO_TOKEN=your-auth-token-here
